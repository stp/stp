(set-logic QF_BV)
(assert (bvuaddo #xFF #x01))
(assert (not (bvuaddo #x7F #x01)))
(assert (bvsaddo #x7F #x01))
(assert (not (bvsaddo #xFF #x01)))
(assert (bvumulo #x10 #x10))
