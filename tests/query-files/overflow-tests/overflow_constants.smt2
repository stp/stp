; RUN: %solver %s | %OutputCheck %s
(set-logic QF_BV)
(assert (bvuaddo #xFF #x01))
(assert (not (bvuaddo #x7F #x01)))
(assert (bvsaddo #x7F #x01))
(assert (not (bvsaddo #xFF #x01)))
(assert (bvumulo #x10 #x10))
(assert (not (bvumulo #x0F #x10)))
(assert (bvsmulo #x40 #x02))
(assert (not (bvsmulo #xFF #x02)))
(assert (bvnego #x80))
(assert (not (bvnego #x7F)))
(assert (bvusubo #x00 #x01))
(assert (not (bvusubo #x05 #x03)))
(assert (bvssubo #x80 #x01))
(assert (bvssubo #x7F #xFF))
(assert (not (bvssubo #x05 #x03)))
(assert (bvsdivo #x80 #xFF))
(assert (not (bvsdivo #x80 #x01)))
(assert (not (bvsdivo #x7F #xFF)))
; CHECK-NEXT: ^sat
(check-sat)
(exit)
